// Baby Kingdom Admin — Prisma Schema
// Migrated from MongoDB/Mongoose → PostgreSQL/Prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 1. User (← auth.model.ts)
// ============================================
model User {
  id          String    @id @default(uuid()) @db.Uuid
  username    String    @unique @db.VarChar(50)
  email       String    @unique @db.VarChar(255)
  passwordHash String  @map("password_hash") @db.VarChar(255)
  role        String    @default("viewer") @db.VarChar(10)
  // role CHECK: admin | editor | approver | viewer
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  claimedFeeds  Feed[] @relation("ClaimedFeeds")
  reviewedFeeds Feed[] @relation("ReviewedFeeds")


  @@map("users")
}

// ============================================
// 2. Config (← config.model.ts)
// ============================================
model Config {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(100)
  value       String   @default("") @db.Text
  category    String   @db.VarChar(20)
  // category CHECK: gemini | bk-forum | medialens | google-trends | scanner | email | general
  description String   @default("") @db.Text
  isSecret    Boolean  @default(false) @map("is_secret")
  updatedBy   String?  @map("updated_by") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("configs")
}

// ============================================
// 3. ToneMode (← tone.model.ts)
// ============================================
model ToneMode {
  id                String  @id @default(uuid()) @db.Uuid
  toneId            String  @unique @map("tone_id") @db.VarChar(50)
  displayName       String  @map("display_name") @db.VarChar(100)
  whenToUse         String? @map("when_to_use") @db.Text
  emotionalRegister String? @map("emotional_register") @db.Text
  openingStyle      String? @map("opening_style") @db.Text
  sentenceStructure String? @map("sentence_structure") @db.Text
  whatToAvoid       String? @map("what_to_avoid") @db.Text
  exampleOpening    String? @map("example_opening") @db.Text
  suitableForTier3  Boolean @default(false) @map("suitable_for_tier3")
  overridePriority  Int     @default(5) @map("override_priority")
  isActive          Boolean @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("tone_modes")
}

// ============================================
// 4. Persona (← persona.model.ts)
// ============================================
model Persona {
  id               String    @id @default(uuid()) @db.Uuid
  accountId        String    @unique @map("account_id") @db.VarChar(50)
  username         String    @db.VarChar(100)
  archetype        String    @db.VarChar(20)
  // archetype CHECK: pregnant | first-time-mom | multi-kid | school-age
  primaryToneMode  String?   @map("primary_tone_mode") @db.VarChar(50)
  secondaryToneMode String?  @map("secondary_tone_mode") @db.VarChar(50)
  avoidedToneMode  String?   @map("avoided_tone_mode") @db.VarChar(50)
  voiceCues        String[]  @default([]) @map("voice_cues")
  catchphrases     String[]  @default([])
  topicBlacklist   String[]  @default([]) @map("topic_blacklist")
  tier3Script      String?   @map("tier3_script") @db.Text
  maxPostsPerDay   Int       @default(3) @map("max_posts_per_day")
  bkPassword       String?   @map("bk_password") @db.Text  // AES encrypted
  bkUid            Int?      @map("bk_uid")
  bkToken          String?   @map("bk_token") @db.Text
  bkTokenExpiry    DateTime? @map("bk_token_expiry") @db.Timestamptz()
  tokenStatus      String    @default("none") @map("token_status") @db.VarChar(10)
  // tokenStatus CHECK: active | expired | none
  lastPostAt       DateTime? @map("last_post_at") @db.Timestamptz()
  postsToday       Int       @default(0) @map("posts_today")
  cooldownUntil    DateTime? @map("cooldown_until") @db.Timestamptz()
  overrideNotes    String?   @map("override_notes") @db.Text
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  boardBindings    BoardPersonaBinding[]

  @@map("personas")
}

// ============================================
// 5. TopicRule (← topic-rules.model.ts)
// ============================================
model TopicRule {
  id                  String   @id @default(uuid()) @db.Uuid
  ruleId              String   @unique @map("rule_id") @db.VarChar(50)
  topicKeywords       String[] @default([]) @map("topic_keywords")
  sensitivityTier     Int      @default(1) @map("sensitivity_tier")
  // sensitivityTier CHECK: 1 | 2 | 3
  sentimentTrigger    String   @default("any") @map("sentiment_trigger") @db.VarChar(20)
  // sentimentTrigger CHECK: any | positive | negative
  priorityAccountIds  String[] @default([]) @map("priority_account_ids")
  assignToneMode      String   @default("auto") @map("assign_tone_mode") @db.VarChar(50)
  postTypePreference  String   @default("any") @map("post_type_preference") @db.VarChar(20)
  // postTypePreference CHECK: new-post | reply | any
  geminiPromptHint    String?  @map("gemini_prompt_hint") @db.Text
  avoidIf             String?  @map("avoid_if") @db.Text
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("topic_rules")
}

// ============================================
// 6. ForumCategory (← forum.model.ts ForumCategory)
// ============================================
model ForumCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  boards ForumBoard[]

  @@map("forum_categories")
}

// ============================================
// 7. ForumBoard (← forum.model.ts ForumBoard)
// ============================================
model ForumBoard {
  id                String    @id @default(uuid()) @db.Uuid
  categoryId        String    @map("category_id") @db.Uuid
  category          ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name              String    @db.VarChar(100)
  fid               Int       @unique
  enableScraping    Boolean   @default(false) @map("enable_scraping")
  enableAutoReply   Boolean   @default(false) @map("enable_auto_reply")
  replyThresholdMin Int       @default(0) @map("reply_threshold_min")
  replyThresholdMax Int       @default(40) @map("reply_threshold_max")
  scanInterval      Int       @default(30) @map("scan_interval")  // minutes
  defaultToneMode   String?   @map("default_tone_mode") @db.VarChar(50)
  defaultRuleIds    String[]  @default([]) @map("default_rule_ids")
  excludeRuleIds    String[]  @default([]) @map("exclude_rule_ids")
  note              String?   @db.Text
  lastScannedAt     DateTime? @map("last_scanned_at") @db.Timestamptz()
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  personaBindings BoardPersonaBinding[]

  @@map("forum_boards")
}

// ============================================
// 7a. BoardPersonaBinding (← ForumBoard.personaBindings subdoc)
// ============================================
model BoardPersonaBinding {
  id        String  @id @default(uuid()) @db.Uuid
  boardId   String  @map("board_id") @db.Uuid
  board     ForumBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  personaId String  @map("persona_id") @db.Uuid
  persona   Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)
  toneMode  String? @map("tone_mode") @db.VarChar(50)
  weight    String  @default("medium") @db.VarChar(10)
  // weight CHECK: high | medium | low
  dailyLimit Int    @default(3) @map("daily_limit")

  @@unique([boardId, personaId])
  @@map("board_persona_bindings")
}

// ============================================
// 8. GoogleTrend (← google-trends.model.ts)
// ============================================
model GoogleTrend {
  id             String    @id @default(uuid()) @db.Uuid
  query          String    @unique @db.VarChar(500)
  score          Int       @default(0)
  peakVolume     Int       @default(0) @map("peak_volume")
  durationHours  Float     @default(0) @map("duration_hours")
  categories     String[]  @default([])
  trendBreakdown String[]  @default([]) @map("trend_breakdown")
  // news → separate table GoogleTrendNews
  analysis       Json?     // IGoogleTrendAnalysis as JSON
  pullId         String    @map("pull_id") @db.VarChar(100)
  pulledAt       DateTime  @map("pulled_at") @db.Timestamptz()
  geo            String    @default("HK") @db.VarChar(10)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  news GoogleTrendNews[]

  @@index([pullId])
  @@index([pulledAt(sort: Desc)])
  @@map("google_trends")
}

// ============================================
// 8a. GoogleTrendNews (← GoogleTrend.news[] subdoc)
// ============================================
model GoogleTrendNews {
  id       String      @id @default(uuid()) @db.Uuid
  trendId  String      @map("trend_id") @db.Uuid
  trend    GoogleTrend @relation(fields: [trendId], references: [id], onDelete: Cascade)
  headline String      @default("") @db.Text
  url      String      @default("") @db.Text

  @@map("google_trend_news")
}

// ============================================
// 9. Feed (← feed.model.ts) — Most complex
// ============================================
model Feed {
  id               String    @id @default(uuid()) @db.Uuid
  feedId           String    @unique @map("feed_id") @db.VarChar(50)
  type             String    @default("reply") @db.VarChar(10)
  // type CHECK: thread | reply
  status           String    @default("pending") @db.VarChar(10)
  // status CHECK: pending | approved | rejected | posted | failed
  source           String[]  @default([])
  // source values: scanner | trends | custom

  // Thread info (scanner source)
  threadTid        Int?      @map("thread_tid")
  threadFid        Int?      @map("thread_fid")
  threadSubject    String?   @map("thread_subject") @db.Text
  threadContent    String?   @map("thread_content") @db.Text
  subject          String?   @db.Text

  // Trend source info
  trendSource      String?   @map("trend_source") @db.VarChar(50)
  trendTopic       String?   @map("trend_topic") @db.Text
  trendSummary     String?   @map("trend_summary") @db.Text
  trendSentiment   Float?    @map("trend_sentiment")
  trendEngagement  Int?      @map("trend_engagement")
  pullTime         DateTime? @map("pull_time") @db.Timestamptz()

  // Generated content
  personaId        String?   @map("persona_id") @db.VarChar(50)
  // Stored as accountId string (not FK UUID) — matches original Mongoose behavior
  bkUsername       String?   @map("bk_username") @db.VarChar(100)
  displayName      String?   @map("display_name") @db.VarChar(100)
  archetype        String?   @db.VarChar(20)
  toneMode         String?   @map("tone_mode") @db.VarChar(50)
  sensitivityTier  String?   @map("sensitivity_tier") @db.VarChar(10)
  postType         String    @default("reply") @map("post_type") @db.VarChar(10)
  // postType CHECK: new-post | reply
  draftContent     String?   @map("draft_content") @db.Text
  finalContent     String?   @map("final_content") @db.Text
  charCount        Int?      @map("char_count")
  adminEdit        Boolean   @default(false) @map("admin_edit")

  // Gemini evaluation
  relevanceScore   Float?    @map("relevance_score")
  worthReplying    Boolean?  @map("worth_replying")

  // Google Trends match
  googleTrends     Json?     @map("google_trends")

  // Post result
  postedAt         DateTime? @map("posted_at") @db.Timestamptz()
  postId           String?   @map("post_id") @db.VarChar(100)
  postUrl          String?   @map("post_url") @db.Text
  failReason       String?   @map("fail_reason") @db.Text

  // Claim
  claimedBy        String?   @map("claimed_by") @db.Uuid
  claimedByUser    User?     @relation("ClaimedFeeds", fields: [claimedBy], references: [id], onDelete: SetNull)
  claimedAt        DateTime? @map("claimed_at") @db.Timestamptz()
  claimExpiresAt   DateTime? @map("claim_expires_at") @db.Timestamptz()

  // Review
  reviewedBy       String?   @map("reviewed_by") @db.Uuid
  reviewedByUser   User?     @relation("ReviewedFeeds", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt       DateTime? @map("reviewed_at") @db.Timestamptz()
  adminNotes       String?   @map("admin_notes") @db.Text

  // Quality
  qualityWarnings  String[]  @default([]) @map("quality_warnings")
  isDuplicate      Boolean   @default(false) @map("is_duplicate")

  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([status, createdAt(sort: Desc)])
  @@index([personaId, status])
  @@index([threadFid, status])
  @@index([claimedBy, claimedAt])
  @@index([status, claimExpiresAt, createdAt])
  @@index([source], type: Gin)
  @@unique([threadTid, personaId])
  @@map("feeds")
}

// ============================================
// 10. Trend (← trends.model.ts)
// ============================================
model Trend {
  id              String   @id @default(uuid()) @db.Uuid
  pullId          String   @map("pull_id") @db.VarChar(100)
  source          String   @db.VarChar(20)
  // source CHECK: medialens | lihkg | facebook
  rank            Int?
  topicLabel      String   @map("topic_label") @db.VarChar(500)
  summary         String?  @db.Text
  engagements     Int?
  postCount       Int?     @map("post_count")
  sensitivityTier Int      @default(1) @map("sensitivity_tier")
  // sensitivityTier CHECK: 1 | 2 | 3
  sentimentScore  Float?   @map("sentiment_score")
  sentimentLabel  String?  @map("sentiment_label") @db.VarChar(20)
  // sentimentLabel CHECK: positive | negative | neutral
  rawData         Json?    @map("raw_data")
  feedIds         String[] @default([]) @map("feed_ids")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([source, topicLabel])
  @@index([source, createdAt(sort: Desc)])
  @@map("trends")
}

// ============================================
// 11. TaskLog — 任务执行日志（替代 queue_jobs）
// ============================================
model TaskLog {
  id          String    @id @default(uuid()) @db.Uuid
  taskName    String    @map("task_name") @db.VarChar(30)
  // taskName: scanner | trends | poster | google-trends
  status      String    @default("running") @db.VarChar(10)
  // status: running | completed | failed | skipped
  duration    Int?      // milliseconds
  result      Json?
  error       String?   @db.Text
  triggeredBy String    @default("cron") @map("triggered_by") @db.VarChar(10)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([taskName, createdAt(sort: Desc)])
  @@map("task_logs")
}

// ============================================
// 12. DailyStats (← dashboard.model.ts)
// Uses JSONB for nested stats — structure changes frequently
// ============================================
model DailyStats {
  id        String   @id @default(uuid()) @db.Uuid
  date      String   @unique @db.VarChar(10)  // YYYY-MM-DD
  scanner   Json     @default("{}")
  feeds     Json     @default("{}")
  trends    Json     @default("{}")
  posts     Json     @default("{}")
  byBoard   Json     @default("[]") @map("by_board")
  byPersona Json     @default("[]") @map("by_persona")
  gemini    Json     @default("{}")
  quality   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("daily_stats")
}

// ============================================
// 14. AuditLog (← audit.model.ts)
// TTL 90 days: handled by Cloud Scheduler + DELETE query
// ============================================
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  operator     String   @db.VarChar(100)
  eventType    String   @map("event_type") @db.VarChar(50)
  module       String   @db.VarChar(20)
  // module CHECK: feed | persona | tone | topic-rules | forum | queue | config | auth | scanner | trends | poster | gemini
  feedId       String?  @map("feed_id") @db.VarChar(50)
  targetId     String?  @map("target_id") @db.VarChar(100)
  bkUsername   String?  @map("bk_username") @db.VarChar(100)
  actionDetail String?  @map("action_detail") @db.Text
  before       Json?    @map("before_data")
  after        Json?    @map("after_data")
  apiStatus    Int?     @map("api_status")
  ip           String?  @db.VarChar(50)
  session      String   @default("admin") @db.VarChar(10)
  // session CHECK: admin | worker | api
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([module, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ============================================
// 15. TokenBlacklist (替代 Redis token blacklist)
// ============================================
model TokenBlacklist {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique @db.Text
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([expiresAt])
  @@map("token_blacklist")
}
